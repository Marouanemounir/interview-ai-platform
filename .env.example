# =============================================================================
# .env.example — InterviewAI Multi-Agent System
# Copier ce fichier en .env et remplir les valeurs avant docker compose up
# Ne jamais commiter le fichier .env dans git (ajouter au .gitignore)
# =============================================================================

# -----------------------------------------------------------------------------
# GENERAL
# -----------------------------------------------------------------------------
APP_ENV=development        # development | production

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_DB=interviewai_db
POSTGRES_USER=interviewai_user
POSTGRES_PASSWORD=change_me_postgres_password
POSTGRES_PORT=5432

# -----------------------------------------------------------------------------
# Qdrant
# -----------------------------------------------------------------------------
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_PASSWORD=change_me_redis_password
REDIS_PORT=6379
REDIS_MAX_MEMORY=256mb

# -----------------------------------------------------------------------------
# MinIO (stockage objets S3-compatible)
# -----------------------------------------------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_minio_password
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# -----------------------------------------------------------------------------
# Whisper STT
# Options modele : tiny | base | small | medium | large-v3
# Recommande : large-v3 pour qualite max, medium si CPU lent
# -----------------------------------------------------------------------------
WHISPER_MODEL=large-v3
WHISPER_LANGUAGE=fr
WHISPER_PORT=9910

# -----------------------------------------------------------------------------
# Coqui TTS
# -----------------------------------------------------------------------------
TTS_PORT=5002

# -----------------------------------------------------------------------------
# Backend FastAPI
# -----------------------------------------------------------------------------
BACKEND_PORT=8000

# -----------------------------------------------------------------------------
# Frontend Next.js
# -----------------------------------------------------------------------------
FRONTEND_PORT=3000

# -----------------------------------------------------------------------------
# Celery / Flower
# -----------------------------------------------------------------------------
FLOWER_PORT=5555
FLOWER_USER=admin
FLOWER_PASSWORD=change_me_flower_password

# -----------------------------------------------------------------------------
# pgAdmin
# -----------------------------------------------------------------------------
PGADMIN_DEFAULT_EMAIL=admin@interviewai.local
PGADMIN_DEFAULT_PASSWORD=change_me_pgadmin_password
PGADMIN_PORT=5050

# -----------------------------------------------------------------------------
# RedisInsight
# -----------------------------------------------------------------------------
REDISINSIGHT_PORT=5540

# -----------------------------------------------------------------------------
# LLM APIs
# -----------------------------------------------------------------------------
GROQ_API_KEY=gsk_...          # Groq API key for LLM inference (llama-3.3-70b-versatile)

# -----------------------------------------------------------------------------
# LangSmith (observabilite des agents — optionnel en dev)
# Creer un compte sur https://smith.langchain.com pour obtenir la cle
# -----------------------------------------------------------------------------
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=interviewai-dev

# -----------------------------------------------------------------------------
# JWT Authentication
# Generer avec : openssl rand -hex 32
# -----------------------------------------------------------------------------
JWT_SECRET_KEY=change_me_generate_with_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30
